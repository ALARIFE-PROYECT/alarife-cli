{
  "name": "alarife-cli",
  "description": "Command line interface tool for Alarife.",
  "version": "0.1.0",
  "author": "Soria Garcia, Jose Eduardo <alarifeproyect@gmail.com>",
  "license": "Apache-2.0",
  "private": false,
  "type": "commonjs",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "bin": {
    "alarife": "./lib/bin.js"
  },
  "files": [
    "lib/**/*"
  ],
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./lib/index.d.ts"
      ]
    }
  },
  "keywords": [
    "alarife"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ALARIFE-PROYECT/alarife-cli.git"
  },
  "homepage": "https://github.com/ALARIFE-PROYECT/alarife-cli#readme",
  "bugs": {
    "url": "https://github.com/ALARIFE-PROYECT/alarife-cli/issues"
  },
  "scripts": {
    "build": "npx tsc --project tsconfig.build.json",
    "test": "npx tsc --project tsconfig.test.json && node --test \"dist/test/**/*.test.js\""
  },
  "dependencies": {
    "@alarife/commander": "~0.6",
    "@alarife/configuration": "~0.3",
    "@alarife/tools": "~1.0",
    "dotenv": "~17.4",
    "tslib": "~2.8"
  },
  "devDependencies": {
    "@types/dotenv": "~6.1.1",
    "@types/node": "~24",
    "typescript": "~6.0"
  }
}
